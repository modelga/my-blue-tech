# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=blue
POSTGRES_PASSWORD=blue
POSTGRES_DB=blue

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── API (apps/api) ───────────────────────────────────────────────────────────
# DATABASE_URL is constructed from POSTGRES_* vars in docker-compose.
# Set this directly when running outside Docker.
DATABASE_URL=postgresql://blue:blue@localhost:5432/blue
KEYCLOAK_ISSUER=http://localhost:8080/realms/blue
PORT=3001

# ── Frontend (apps/frontend) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=blue
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=blue-frontend
