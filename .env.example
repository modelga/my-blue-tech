# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=blue
POSTGRES_PASSWORD=blue
POSTGRES_DB=blue

# ── API (apps/api) ───────────────────────────────────────────────────────────
# DATABASE_URL is constructed from POSTGRES_* vars in docker-compose.
# Set this directly when running outside Docker.
DATABASE_URL=postgresql://blue:blue@localhost:5432/blue
PORT=3001
